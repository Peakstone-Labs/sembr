<!DOCTYPE html>
{#
  Print-oriented digest template, independent from the HTML email template.
  Targets WeasyPrint: A4 page CSS, monochrome citations (no score badges or
  coloured chrome), and clickable source URLs. Uses only CSS2.1-level styling
  (no flexbox/grid) because WeasyPrint's flexbox support is limited.
#}
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  @page { size: A4; margin: 2cm; }
  body { font-family: "Helvetica Neue", Arial, sans-serif; color: #000; font-size: 11pt; line-height: 1.5; margin: 0; }
  .title { font-size: 14pt; font-weight: 700; margin: 0 0 2pt; }
  .date { font-size: 10pt; color: #444; margin: 0 0 16pt; }
  .summary { font-size: 11pt; line-height: 1.55; }
  .summary h1, .summary h2, .summary h3, .summary h4 { font-size: 12pt; font-weight: 700; margin: 12pt 0 4pt; }
  .summary p { margin: 0 0 8pt; }
  .summary ul, .summary ol { margin: 4pt 0 8pt; padding-left: 20pt; }
  .summary li { margin: 2pt 0; }
  .summary code { font-family: "Courier New", monospace; font-size: 10pt; }
  .summary table { border-collapse: collapse; width: 100%; margin: 8pt 0; }
  .summary th, .summary td { border: 1px solid #999; padding: 4pt 8pt; font-size: 10pt; text-align: left; }
  .summary sup.cite-ref a { color: #000; text-decoration: none; }
  .sources-heading { font-size: 11pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #000; padding-bottom: 3pt; margin: 20pt 0 8pt; }
  ol.sources { list-style: none; margin: 0; padding: 0; }
  ol.sources li { margin: 0 0 8pt; font-size: 10pt; page-break-inside: avoid; }
  ol.sources .idx { font-weight: 700; }
  ol.sources .stitle { font-weight: 600; }
  ol.sources a { color: #000; text-decoration: underline; word-break: break-all; }
  ol.sources .meta { color: #444; font-size: 9pt; }
  .footer { margin-top: 24pt; padding-top: 8pt; border-top: 1px solid #ccc; text-align: center; color: #888; font-size: 9pt; }
</style>
</head>
<body>
  <div class="title">{{ intent_name }}</div>
  <div class="date">{{ digest_date }}</div>
  <div class="summary">{{ summary_html }}</div>
  {% if citations %}
  <div class="sources-heading">Sources</div>
  <ol class="sources">
    {% for c in citations %}
    <li id="cite-{{ c.index }}">
      <span class="idx">[{{ c.index }}]</span>
      <span class="stitle">{{ c.title }}</span><br>
      <a href="{{ c.url }}">{{ c.url }}</a><br>
      <span class="meta">{{ c.source_name }}{% if c.datetime_display %} · {{ c.datetime_display }}{% endif %}</span>
    </li>
    {% endfor %}
  </ol>
  {% endif %}
  <div class="footer">Generated by sembr — github.com/Peakstone-Labs/sembr</div>
</body>
</html>
