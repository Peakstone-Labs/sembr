<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  body { font-family: Arial, Helvetica, sans-serif; color: #333; margin: 0; padding: 0; background: #f5f5f5; }
  .wrapper { max-width: 600px; margin: 0 auto; background: #fff; }
  .header { background: #1a1a2e; color: #fff; padding: 18px 24px; }
  .header h1 { font-size: 18px; margin: 0; font-weight: 600; }
  .summary-block { background: #f0f4ff; border-left: 4px solid #4a6cf7; padding: 16px 20px; margin: 20px 24px; border-radius: 4px; font-size: 14px; line-height: 1.6; }
  .summary-block h1, .summary-block h2, .summary-block h3, .summary-block h4 { margin: 14px 0 6px; font-size: 15px; font-weight: 700; color: #1a1a2e; }
  .summary-block h1:first-child, .summary-block h2:first-child, .summary-block h3:first-child { margin-top: 0; }
  .summary-block p { margin: 0 0 10px; }
  .summary-block p:last-child { margin-bottom: 0; }
  .summary-block ul, .summary-block ol { margin: 6px 0 10px; padding-left: 22px; }
  .summary-block li { margin: 3px 0; }
  .summary-block strong { color: #1a1a2e; }
  .summary-block code { background: #e6ebff; padding: 1px 4px; border-radius: 3px; font-size: 13px; }
  .summary-block sup.cite-ref { font-size: 11px; }
  .summary-block sup.cite-ref a { color: #4a6cf7; text-decoration: none; padding: 0 1px; }
  .summary-block sup.cite-ref a:hover { text-decoration: underline; }
  .section { padding: 0 24px 16px; }
  .section-heading { font-size: 12px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #eee; padding-bottom: 6px; margin: 16px 0 8px; }
  .article-list { list-style: none; margin: 0; padding: 0; counter-reset: cite; }
  .article-list li { padding: 6px 0; font-size: 14px; display: flex; align-items: baseline; gap: 8px; }
  .article-list .idx { flex: 0 0 auto; min-width: 28px; font-size: 12px; color: #888; font-variant-numeric: tabular-nums; }
  .article-list .body { flex: 1 1 auto; }
  .article-list a { color: #4a6cf7; text-decoration: none; }
  .article-list a:hover { text-decoration: underline; }
  .article-meta { display: block; font-size: 12px; color: #888; margin-top: 2px; }
  .score-badge { display: inline-block; background: #e6ebff; color: #4a6cf7; font-size: 11px; font-weight: 600; padding: 1px 6px; border-radius: 8px; margin-right: 6px; font-variant-numeric: tabular-nums; }
  .footer { border-top: 1px solid #eee; padding: 16px 24px; font-size: 11px; color: #999; text-align: center; }
</style>
</head>
<body>
<div class="wrapper" style="max-width:600px;margin:0 auto;background:#fff;">
  <div class="header" style="background:#1a1a2e;color:#fff;padding:18px 24px;">
    <h1 style="font-size:18px;margin:0;font-weight:600;">{{ intent_name }} - {{ digest_date }}</h1>
  </div>
  <div class="summary-block" style="background:#f0f4ff;border-left:4px solid #4a6cf7;padding:16px 20px;margin:20px 24px;border-radius:4px;font-size:14px;line-height:1.6;">
    {{ summary_html }}
  </div>
  <div class="section" style="padding:0 24px 16px;">
    <div class="section-heading" style="font-size:12px;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.05em;border-bottom:1px solid #eee;padding-bottom:6px;margin:16px 0 8px;">
      Sources
    </div>
    <ul class="article-list" style="list-style:none;margin:0;padding:0;">
      {% for c in citations %}
      <li id="cite-{{ c.index }}" style="padding:6px 0;font-size:14px;">
        <span class="idx" style="display:inline-block;min-width:28px;font-size:12px;color:#888;">[{{ c.index }}]</span>
        <span class="body">
          <a href="{{ c.url }}" style="color:#4a6cf7;text-decoration:none;">{{ c.title }}</a>
          <span class="article-meta" style="display:block;font-size:12px;color:#888;margin-top:2px;">
            {% if c.score_display %}<span class="score-badge" style="display:inline-block;background:#e6ebff;color:#4a6cf7;font-size:11px;font-weight:600;padding:1px 6px;border-radius:8px;margin-right:6px;font-variant-numeric:tabular-nums;">{{ c.score_display }}</span>{% endif %}{{ c.source_name }}{% if c.datetime_display %} · {{ c.datetime_display }}{% endif %}
          </span>
        </span>
      </li>
      {% endfor %}
    </ul>
  </div>
  <div class="footer" style="border-top:1px solid #eee;padding:16px 24px;font-size:11px;color:#999;text-align:center;">
    Generated by <a href="https://github.com/Peakstone-Labs/sembr" style="color:#4a6cf7;text-decoration:none;font-weight:600;">sembr</a>
  </div>
</div>
</body>
</html>
