<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  body { font-family: Arial, Helvetica, sans-serif; color: #333; margin: 0; padding: 0; background: #f5f5f5; }
  .wrapper { max-width: 600px; margin: 0 auto; background: #fff; }
  .header { background: #1a1a2e; color: #fff; padding: 20px 24px; }
  .header .brand { font-size: 13px; color: #aaa; margin: 0 0 4px; }
  .header h1 { font-size: 18px; margin: 0; font-weight: 600; }
  .summary-block { background: #f0f4ff; border-left: 4px solid #4a6cf7; padding: 16px 20px; margin: 20px 24px; border-radius: 4px; font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
  .section { padding: 0 24px 16px; }
  .date-heading { font-size: 12px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #eee; padding-bottom: 6px; margin: 16px 0 8px; }
  .article-list { list-style: none; margin: 0; padding: 0; }
  .article-list li { padding: 4px 0; font-size: 14px; }
  .article-list a { color: #4a6cf7; text-decoration: none; }
  .article-list a:hover { text-decoration: underline; }
  .footer { border-top: 1px solid #eee; padding: 16px 24px; font-size: 11px; color: #999; text-align: center; }
</style>
</head>
<body>
<div class="wrapper" style="max-width:600px;margin:0 auto;background:#fff;">
  <div class="header" style="background:#1a1a2e;color:#fff;padding:20px 24px;">
    <p class="brand" style="font-size:13px;color:#aaa;margin:0 0 4px;">sembr</p>
    <h1 style="font-size:18px;margin:0;font-weight:600;">{{ intent_name }}</h1>
  </div>
  <div class="summary-block" style="background:#f0f4ff;border-left:4px solid #4a6cf7;padding:16px 20px;margin:20px 24px;border-radius:4px;font-size:14px;line-height:1.6;white-space:pre-wrap;">
    {{ summary }}
  </div>
  <div class="section" style="padding:0 24px 16px;">
    {% for date_key, citations in grouped %}
    <div class="date-heading" style="font-size:12px;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.05em;border-bottom:1px solid #eee;padding-bottom:6px;margin:16px 0 8px;">
      {% if date_key is none %}Date unknown{% else %}{{ date_key }}{% endif %}
    </div>
    <ul class="article-list" style="list-style:none;margin:0;padding:0;">
      {% for c in citations %}
      <li style="padding:4px 0;font-size:14px;">
        <a href="{{ c.url }}" style="color:#4a6cf7;text-decoration:none;">{{ c.title }}</a>
      </li>
      {% endfor %}
    </ul>
    {% endfor %}
  </div>
  <div class="footer" style="border-top:1px solid #eee;padding:16px 24px;font-size:11px;color:#999;text-align:center;">
    Generated by <strong>sembr</strong>
  </div>
</div>
</body>
</html>
