# Copy to .env and uncomment only what you need to override.
# Settings precedence (low → high): defaults < sembr.yaml < .env < shell env vars.
# Leaving a value commented here means the default in sembr/config.py wins,
# which keeps the yaml-tier of the chain observable.

# API bind — change only if you have a port conflict inside the container.
# API_HOST=0.0.0.0
# API_PORT=8000

# Storage — override when running outside Docker or with a remote Qdrant.
# QDRANT_URL=http://qdrant:6333
# SQLITE_PATH=/app/data/sembr.db

# Host port exposed by Docker Compose (does not affect in-container bind port).
# SEMBR_HOST_PORT=8000

# Embedder backend (siliconflow is the only supported value in this release).
# EMBEDDER_BACKEND=siliconflow

# SiliconFlow API key — required; the service will refuse to start without it.
EMBEDDER_API_KEY=sk-your-siliconflow-key-here

# Override the embeddings endpoint (optional — any OpenAI-compatible /v1/embeddings).
# EMBEDDER_API_BASE_URL=https://api.siliconflow.cn/v1

# Override the model name on the endpoint (optional).
# EMBEDDER_MODEL=BAAI/bge-m3

# Per-request HTTP timeout in seconds (optional, default 30).
# EMBEDDER_TIMEOUT_SECONDS=30
