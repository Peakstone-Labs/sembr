# Copy to .env and fill in the required values.
# Settings precedence (low → high): defaults < sembr.yaml < .env < shell env vars.

# ── Storage ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
SQLITE_PATH=/app/data/sembr.db

# ── Embedder (SiliconFlow BGE-M3) ─────────────────────────────────────────────
EMBEDDER_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — get your key at https://siliconflow.cn
EMBEDDER_API_KEY=sk-your-siliconflow-key-here
EMBEDDER_MODEL=BAAI/bge-m3
# Probe + httpx default timeout. Batch calls use dynamic max(30s, chars/1500),
# so values < 30 do NOT shorten batch-path timeouts.
EMBEDDER_TIMEOUT_SECONDS=30

# ── LLM summarizer (SiliconFlow DeepSeek) ─────────────────────────────────────
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — can reuse the same SiliconFlow key as above
LLM_API_KEY=sk-your-siliconflow-key-here
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_TIMEOUT_SECONDS=60
# Total prompt-side character budget (system + instruction + assembled articles).
# The pipeline reserves ~15% for the response, then water-fills article bodies
# into the remainder — short articles stay whole, only the longest get truncated.
#
# Tune to your model's context window. Characters, not tokens — Chinese ≈ 1–1.7
# chars/token, English ≈ 4 chars/token, so the safe budget depends on language mix.
#
#   1M-token ctx  (DeepSeek-V4-Flash, default):  1_500_000 — comfortable for
#       mixed-language news; bump to 3_000_000 if you're English-only and want
#       more articles per digest, drop to 1_000_000 if your feeds are pure
#       Chinese AND you regularly hit very long articles.
#   128K-token ctx:                              ~200_000
#   8K-token ctx (local 7B/8B):                  ~16_000
#
# Lower bound 2_000.
LLM_MAX_PROMPT_CHARS=1500000

# ── Email (SMTP) notification channel ─────────────────────────────────────────
# Leave SMTP_HOST empty to disable email push entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# ── Display ───────────────────────────────────────────────────────────────────
# IANA timezone used to render published_at in notifications.
DISPLAY_TIMEZONE=Asia/Shanghai

# ── RSSHub ────────────────────────────────────────────────────────────────────
# RSSHub reads these vars directly — prefix conflicts with sembr vars are safe
# (RSSHub ignores unknown vars; sembr ignores TWITTER_* / RSSHUB_* vars).
#
# Twitter/X auth_token — needed for user timelines and keyword search.
# How to get: log in to x.com → DevTools (F12) → Application → Cookies →
#   https://x.com → copy the value of the `auth_token` cookie (40-char hex).
#   For multiple accounts, separate with commas (RSSHub rotates between them).
TWITTER_AUTH_TOKEN=
#
# Telegram — needed for private/restricted channel feeds.
# TELEGRAM_TOKEN is a bot token (BotFather); TELEGRAM_SESSION is a user session
# string (required for restricted channels, generated via Telethon/Pyrogram).
TELEGRAM_TOKEN=
TELEGRAM_SESSION=
#
# GitHub PAT — raises API rate limit from 60 to 5000 req/h.
# Needed if you subscribe to many GitHub repos/trending feeds.
GITHUB_ACCESS_TOKEN=

# ── Monitoring dashboard ──────────────────────────────────────────────────────
# Optional shared token gating /dashboard and /api/dashboard.
# Empty (default) = no auth. Set this whenever the host is reachable from
# anything beyond localhost — feed URLs and dead-article error messages are
# otherwise public.
DASHBOARD_TOKEN=
# Maximum age (days) of rows kept in feed_fetch_log / embed_call_log.
DASHBOARD_LOG_RETENTION_DAYS=7
# Per-feed cap on retained feed_fetch_log rows (older rows pruned in FIFO order).
DASHBOARD_LOG_MAX_PER_FEED=1000
# Frontend polling cadence in seconds; surfaced via /api/dashboard/config.
DASHBOARD_POLL_INTERVAL_SECONDS=10
# Default level applied to all 7 LogBus tags on startup (DEBUG / INFO / WARNING / ERROR).
# Runtime PUT /api/dashboard/logs/level can adjust per-tag in process memory.
DASHBOARD_LOG_LEVEL=INFO
# Ring buffer capacity per log tag (number of records held in memory).
# Memory ≈ 7 × buffer × ~500 B; 1000 ≈ 3.5 MB, max 10000 ≈ 35 MB.
DASHBOARD_LOG_BUFFER_PER_TAG=1000

# ── Network exposure ──────────────────────────────────────────────────────────
# Host-side port published by docker compose (in-container bind is hardcoded
# to 8000 in the Dockerfile CMD).
# SEMBR_HOST_PORT=8000
# Host-side bind address. Default 127.0.0.1 = loopback only (the API is
# unreachable from outside the host). To expose sembr on a LAN-only home
# server set 0.0.0.0. For PUBLIC INTERNET deployment, leave this at
# 127.0.0.1 and put sembr behind a reverse proxy with TLS — see
# docs/deployment/public.md for the full hardening checklist.
# SEMBR_HOST_BIND=127.0.0.1

# ── Lifespan / restart ────────────────────────────────────────────────────────
# Max seconds for graceful lifespan shutdown before forcing exit. Set below
# docker stop's SIGKILL deadline (default 10s). Only applies to self-restart
# paths (settings save → SIGTERM); a normal `docker compose down` is unaffected.
LIFESPAN_SHUTDOWN_TIMEOUT=8
