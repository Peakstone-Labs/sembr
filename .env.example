# Copy to .env and fill in the required values.
# Settings precedence (low → high): defaults < sembr.yaml < .env < shell env vars.

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
SQLITE_PATH=/app/data/sembr.db

# Host port exposed by Docker Compose (does not affect in-container bind port).
SEMBR_HOST_PORT=8000

# ── Embedder (SiliconFlow BGE-M3) ─────────────────────────────────────────────
EMBEDDER_BACKEND=siliconflow
EMBEDDER_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — get your key at https://siliconflow.cn
EMBEDDER_API_KEY=sk-your-siliconflow-key-here
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_TIMEOUT_SECONDS=30

# ── LLM summarizer (SiliconFlow DeepSeek) ─────────────────────────────────────
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — can reuse the same SiliconFlow key as above
LLM_API_KEY=sk-your-siliconflow-key-here
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_TIMEOUT_SECONDS=60
# difflib title-similarity threshold for grouping same-event articles (0.0–1.0)
LLM_GROUPING_THRESHOLD=0.85

# ── Email (SMTP) notification channel ─────────────────────────────────────────
# Leave SMTP_HOST empty to disable email push entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# ── Display ───────────────────────────────────────────────────────────────────
# IANA timezone used to render published_at in notifications.
DISPLAY_TIMEZONE=Asia/Shanghai

# ── RSSHub ────────────────────────────────────────────────────────────────────
# RSSHub reads these vars directly — prefix conflicts with sembr vars are safe
# (RSSHub ignores unknown vars; sembr ignores TWITTER_* / RSSHUB_* vars).
#
# Twitter/X cookie — needed for user timelines and keyword search.
# How to get: log in to x.com → DevTools (F12) → Network → any request →
#   Headers → Request Headers → Cookie → copy the full value.
#   You need at minimum: auth_token=...; ct0=...
TWITTER_COOKIE=
#
# Telegram — needed for private/restricted channel feeds.
# TELEGRAM_TOKEN is a bot token (BotFather); TELEGRAM_SESSION is a user session
# string (required for restricted channels, generated via Telethon/Pyrogram).
TELEGRAM_TOKEN=
TELEGRAM_SESSION=
#
# GitHub PAT — raises API rate limit from 60 to 5000 req/h.
# Needed if you subscribe to many GitHub repos/trending feeds.
GITHUB_ACCESS_TOKEN=

# ── Monitoring dashboard ──────────────────────────────────────────────────────
# Optional shared token gating /dashboard and /api/dashboard.
# Empty (default) = no auth. Set this whenever the host is reachable from
# anything beyond localhost — feed URLs and dead-article error messages are
# otherwise public.
DASHBOARD_TOKEN=
# Maximum age (days) of rows kept in feed_fetch_log / embed_call_log.
DASHBOARD_LOG_RETENTION_DAYS=7
# Per-feed cap on retained feed_fetch_log rows (older rows pruned in FIFO order).
DASHBOARD_LOG_MAX_PER_FEED=1000
# Frontend polling cadence in seconds; surfaced via /api/dashboard/config.
DASHBOARD_POLL_INTERVAL_SECONDS=10
