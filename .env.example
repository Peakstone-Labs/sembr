# Copy to .env and fill in the required values.
# Settings precedence (low → high): defaults < sembr.yaml < .env < shell env vars.

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
SQLITE_PATH=/app/data/sembr.db

# Host port exposed by Docker Compose (does not affect in-container bind port).
SEMBR_HOST_PORT=8000

# ── Embedder (SiliconFlow BGE-M3) ─────────────────────────────────────────────
EMBEDDER_BACKEND=siliconflow
EMBEDDER_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — get your key at https://siliconflow.cn
EMBEDDER_API_KEY=sk-your-siliconflow-key-here
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_TIMEOUT_SECONDS=30

# ── LLM summarizer (SiliconFlow DeepSeek) ─────────────────────────────────────
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
# Required — can reuse the same SiliconFlow key as above
LLM_API_KEY=sk-your-siliconflow-key-here
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_TIMEOUT_SECONDS=60
# difflib title-similarity threshold for grouping same-event articles (0.0–1.0)
LLM_GROUPING_THRESHOLD=0.85

# ── Email (SMTP) notification channel ─────────────────────────────────────────
# Leave SMTP_HOST empty to disable email push entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# ── Display ───────────────────────────────────────────────────────────────────
# IANA timezone used to render published_at in notifications.
DISPLAY_TIMEZONE=Asia/Shanghai
