# Copy to .env and edit. .env is gitignored.
# Settings precedence: defaults < sembr.yaml < .env < shell env vars.

# API
API_HOST=0.0.0.0
API_PORT=8000

# Storage
QDRANT_URL=http://qdrant:6333
SQLITE_PATH=/app/data/sembr.db

# Embedder backend selector (real model load lands in a later feature).
# docker_cpu | host_mlx
EMBEDDER_BACKEND=docker_cpu
